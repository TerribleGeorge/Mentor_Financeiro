  "strategy_sectionCoreTitle": "Amasu abalulekile\nI-",
  "strategy_sectionDeepDiveTitle": "I-Deep Dive (i-Premium)",
  "strategy_emergencyFundTitle": "Isikhwama sezimo eziphuthumayo",
  "strategy_emergencyFundBodyBr": "Isihlangu sakho sezezimali. Khava izinyanga ezingu-6-12 zezindleko. Beka kuqala imali yansuku zonke nobungozi obuncane (isb., i-Tesouro Selic noma i-CDB exhunywe kwi-CDI).",
  "strategy_emergencyFundBodyGlobal": "Isihlangu sakho sezezimali. Khava izinyanga ezingu-6-12 zezindleko. Beka kuqala imali yansuku zonke kanye nengcuphe ephansi (isb., izimali zemakethe yemali kanye namabhondi e-Treasury yesikhashana).\nThenga futhi ubambe.",
  "strategy_buyHoldTitle": "",
  "strategy_buyHoldBody": "Thenga izimpahla zekhwalithi futhi ubambe isikhathi eside. Gxila ekuziphatheni, ikhwalithi, kanye nokutshala kabusha ngokuhamba kwesikhathi.\nIzingxenye ze-",
  "strategy_diversificationTitle": "",
  "strategy_diversificationBodyBr": "Sabalalisa imali yakho emalini engenayo engaguquki, amasheya, ama-FII, nezimpahla zamazwe ngamazwe ukuze unciphise ubungozi futhi uthuthukise izinzuzo ezilungiswe ubungozi.",
  "strategy_diversificationBodyGlobal": "Sabalalisa imali yakho kuwo wonke amabhondi, amasheya, ama-REIT, nokuchayeka kwamanye amazwe ukuze unciphise ubungozi futhi uthuthukise imbuyiselo elungiswe ubungozi.\nI-",
  "strategy_dcaTitle": "Isilinganiso sezindleko zedola (DCA)",
  "strategy_dcaBody": "Ukuvumelana kwehlula ubuhlakani. Ukutshala imali njalo ngenyanga kuvame ukusebenza kangcono kunokuzama ukukhetha indawo ekahle yokungena.\nIzinhloso ze-SMART",
  "strategy_smartGoalsTitle": "",
  "strategy_smartGoalsBody": "Imigomo yakho kufanele icace, ilinganiseke, ifezeke, ihambisane, futhi ihambisane nesikhathi.\nIdatha ye-",
  "strategy_503020Title": "50-30-20",
  "strategy_503020Body": "Uhlaka lwesabelomali olulula: 50% udinga, 30% ufuna, 20% ukutshala izimali kanye nemigomo.\nI-",
  "strategy_deepDive_allocationTitle": "Isabelo sempahla (esithuthukisiwe)",
  "strategy_deepDive_allocationBody": "Funda ukuthi ungakha kanjani isabelo ngomgomo nasemkhathizwe, ukulungisa ubungozi, ukuhlobanisa, nokulinganisa kabusha.\nI-",
  "strategy_deepDive_globalEtfsTitle": "Global ETFs kanye nezinkomba (ezithuthukisiwe)",
  "strategy_deepDive_globalEtfsBody": "Funda mayelana nezinkomba zomhlaba (isb., S&P 500), ama-ETF, nokuthi ungakha kanjani ukuchayeka kwamanye amazwe ngokuziphatha.",
  "strategy_deepDive_taxesTitle": "Izintela nokubika (okuthuthukisiwe)",
  "strategy_deepDive_taxesBody": "Qonda imiqondo yentela ewumongo kanye nendlela yokugcina amarekhodi ukuze ubike ukutshalwa kwezimali ngokuphepha.\nIntengo ye-",
  "strategy_premiumLockedBody": "Yenza kusebenze itimu ye-Cyber/Grimm/Hive ukuze uvule i-investimenti ye-Deep Dive.\nIdatha ye-",
