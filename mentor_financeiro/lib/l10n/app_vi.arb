  "strategy_sectionCoreTitle": "Chiến lược thiết yếu\nLặn sâu",
  "strategy_sectionDeepDiveTitle": "(Cao cấp)\nQuỹ khẩn cấp",
  "strategy_emergencyFundTitle": "",
  "strategy_emergencyFundBodyBr": "Lá chắn tài chính của bạn. Chi trả chi phí từ 6–12 tháng. Ưu tiên thanh khoản hàng ngày và rủi ro thấp (ví dụ: Tesouro Selic hoặc CDB được liên kết với CDI).",
  "strategy_emergencyFundBodyGlobal": "Lá chắn tài chính của bạn. Chi trả chi phí từ 6–12 tháng. Ưu tiên thanh khoản hàng ngày và rủi ro thấp (ví dụ: quỹ thị trường tiền tệ và trái phiếu kho bạc ngắn hạn).",
  "strategy_buyHoldTitle": "Mua và Giữ",
  "strategy_buyHoldBody": "Mua tài sản chất lượng và nắm giữ lâu dài. Tập trung vào kỷ luật, chất lượng và tái đầu tư theo thời gian.",
  "strategy_diversificationTitle": "Đa dạng hóa",
  "strategy_diversificationBodyBr": "Phân bổ vốn của bạn cho thu nhập cố định, cổ phiếu, FII và tài sản quốc tế để giảm rủi ro và cải thiện lợi nhuận được điều chỉnh theo rủi ro.",
  "strategy_diversificationBodyGlobal": "Phân bổ vốn của bạn vào trái phiếu, cổ phiếu, REIT và rủi ro quốc tế để giảm rủi ro và cải thiện lợi nhuận được điều chỉnh theo rủi ro.",
  "strategy_dcaTitle": "Tính trung bình chi phí bằng đô la (DCA)",
  "strategy_dcaBody": "Tính nhất quán đánh bại thiên tài. Đầu tư hàng tháng thường hiệu quả hơn việc cố gắng chọn điểm vào lệnh hoàn hảo.\nMục tiêu THÔNG MINH",
  "strategy_smartGoalsTitle": "",
  "strategy_smartGoalsBody": "Mục tiêu của bạn phải cụ thể, đo lường được, có thể đạt được, phù hợp và có thời hạn.\nQuy tắc",
  "strategy_503020Title": "50-30-20",
  "strategy_503020Body": "Một khuôn khổ lập ngân sách đơn giản: 50% nhu cầu, 30% mong muốn, 20% đầu tư và mục tiêu.",
  "strategy_deepDive_allocationTitle": "Phân bổ tài sản (nâng cao)",
  "strategy_deepDive_allocationBody": "Tìm hiểu cách xây dựng phân bổ theo mục tiêu và tầm nhìn, điều chỉnh rủi ro, mối tương quan và tái cân bằng.",
  "strategy_deepDive_globalEtfsTitle": "ETF và chỉ số toàn cầu (nâng cao)",
  "strategy_deepDive_globalEtfsBody": "Tìm hiểu về các chỉ số toàn cầu (ví dụ: S&P 500), quỹ ETF và cách xây dựng khả năng tiếp cận quốc tế một cách kỷ luật.",
  "strategy_deepDive_taxesTitle": "Thuế và báo cáo (nâng cao)",
  "strategy_deepDive_taxesBody": "Hiểu các khái niệm cốt lõi về thuế và cách lưu giữ hồ sơ để báo cáo khoản đầu tư một cách an toàn.",
  "strategy_premiumLockedBody": "Nội dung cao cấp. Kích hoạt chủ đề Cyber/Grimm/Hive để mở khóa khoản đầu tư Deep Dive.\nPhòng trưng bày",
  "homeShowcaseTitle": "",
  "homeShowcaseProfileSimTitle": "Câu hỏi về hồ sơ rủi ro",
  "homeShowcaseProfileSimSubtitle": "Tìm hồ sơ nhà đầu tư của bạn trong vài phút.",
  "homeShowcaseStrategiesTitle": "Chiến lược được đề xuất",
  "homeShowcaseStrategiesSubtitle": "Phím tắt trực tiếp để tìm hiểu và áp dụng các chiến lược.\nNgười cố vấn",
  "homeShowcaseMentorHubTitle": ": Câu đố & Chiến lược",
  "homeShowcaseMentorHubSubtitle": "Truy cập nhanh vào bài kiểm tra hồ sơ rủi ro và các chiến lược được đề xuất.",
  "homeTourStepClassicTitle": "Chế độ cổ điển",
  "homeTourStepClassicBody": "Mở bảng ứng dụng gốc: giao dịch, mục tiêu, đầu tư và cài đặt theo bố cục quen thuộc.\nKhu vực trưng bày",
  "homeTourStepVitrineTitle": "",
  "homeTourStepVitrineBody": "Các phím tắt để học và thực hành: hồ sơ nhà đầu tư, chiến lược và trung tâm Mentor.\nCâu đố hồ sơ",
  "homeTourStepProfileTitle": "",
  "homeTourStepProfileBody": "Trả lời bảng câu hỏi để khám phá hồ sơ rủi ro của bạn và xem các đề xuất phù hợp.\nChiến lược",
  "homeTourStepStrategiesTitle": "",
  "homeTourStepStrategiesBody": "Nội dung tổ chức tài chính, đầu tư có kỷ luật và tránh những cạm bẫy thường gặp.\nTrung tâm cố vấn",
  "homeTourStepHubTitle": "",
  "homeTourStepHubBody": "Menu nhanh cho bài kiểm tra hồ sơ và các chiến lược được đề xuất.\nTính năng cao cấp của",
  "homeTourStepPremiumTitle": "",
  "homeTourStepPremiumBody": "Tư vấn tự động, biểu đồ nâng cao và báo cáo hàng tháng — có sẵn khi đăng ký Premium.",
  "homeTourStepMarketTitle": "Ảnh chụp nhanh thị trường",
  "homeTourStepMarketBody": "Bối cảnh thị trường (Brazil hoặc toàn cầu) dựa trên khu vực của bạn cộng với giá trị ròng được chuyển đổi.\nMáy tính Mentor",
  "homeTourStepCalculatorTitle": "",
  "homeTourStepCalculatorBody": "Mô phỏng lãi kép, lạm phát và xem biểu đồ tài sản; tiếp theo chúng ta mở công cụ này.\nCâu hỏi về hồ sơ rủi ro",
