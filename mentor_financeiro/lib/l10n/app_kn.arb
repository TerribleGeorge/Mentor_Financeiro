  "strategy_sectionCoreTitle": "ಅಗತ್ಯ ತಂತ್ರಗಳು",
  "strategy_sectionDeepDiveTitle": "ಡೀಪ್ ಡೈವ್ (ಪ್ರೀಮಿಯಂ)",
  "strategy_emergencyFundTitle": "ತುರ್ತು ನಿಧಿ",
  "strategy_emergencyFundBodyBr": "ನಿಮ್ಮ ಹಣಕಾಸಿನ ಗುರಾಣಿ. 6-12 ತಿಂಗಳ ಖರ್ಚುಗಳನ್ನು ಕವರ್ ಮಾಡಿ. ದೈನಂದಿನ ದ್ರವ್ಯತೆ ಮತ್ತು ಕಡಿಮೆ ಅಪಾಯಕ್ಕೆ ಆದ್ಯತೆ ನೀಡಿ (ಉದಾ., ಟೆಸೌರೊ ಸೆಲಿಕ್ ಅಥವಾ ಸಿಡಿಐ-ಲಿಂಕ್ಡ್ ಸಿಡಿಬಿ).",
  "strategy_emergencyFundBodyGlobal": "ನಿಮ್ಮ ಹಣಕಾಸಿನ ಗುರಾಣಿ. 6-12 ತಿಂಗಳ ಖರ್ಚುಗಳನ್ನು ಕವರ್ ಮಾಡಿ. ದೈನಂದಿನ ದ್ರವ್ಯತೆ ಮತ್ತು ಕಡಿಮೆ ಅಪಾಯಕ್ಕೆ ಆದ್ಯತೆ ನೀಡಿ (ಉದಾಹರಣೆಗೆ, ಹಣದ ಮಾರುಕಟ್ಟೆ ನಿಧಿಗಳು ಮತ್ತು ಅಲ್ಪಾವಧಿಯ ಖಜಾನೆ ಬಾಂಡ್‌ಗಳು).",
  "strategy_buyHoldTitle": "ಖರೀದಿಸಿ ಮತ್ತು ಹಿಡಿದುಕೊಳ್ಳಿ",
  "strategy_buyHoldBody": "ಗುಣಮಟ್ಟದ ಸ್ವತ್ತುಗಳನ್ನು ಖರೀದಿಸಿ ಮತ್ತು ದೀರ್ಘಾವಧಿಯವರೆಗೆ ಹಿಡಿದುಕೊಳ್ಳಿ. ಕಾಲಾನಂತರದಲ್ಲಿ ಶಿಸ್ತು, ಗುಣಮಟ್ಟ ಮತ್ತು ಮರುಹೂಡಿಕೆಯ ಮೇಲೆ ಕೇಂದ್ರೀಕರಿಸಿ.",
  "strategy_diversificationTitle": "ವೈವಿಧ್ಯೀಕರಣ",
  "strategy_diversificationBodyBr": "ಅಪಾಯವನ್ನು ಕಡಿಮೆ ಮಾಡಲು ಮತ್ತು ಅಪಾಯ-ಹೊಂದಾಣಿಕೆಯ ಆದಾಯವನ್ನು ಸುಧಾರಿಸಲು ಸ್ಥಿರ ಆದಾಯ, ಷೇರುಗಳು, FII ಗಳು ಮತ್ತು ಅಂತರರಾಷ್ಟ್ರೀಯ ಸ್ವತ್ತುಗಳಾದ್ಯಂತ ನಿಮ್ಮ ಬಂಡವಾಳವನ್ನು ಹರಡಿ.",
  "strategy_diversificationBodyGlobal": "ಅಪಾಯವನ್ನು ಕಡಿಮೆ ಮಾಡಲು ಮತ್ತು ಅಪಾಯ-ಹೊಂದಾಣಿಕೆಯ ಆದಾಯವನ್ನು ಸುಧಾರಿಸಲು ಬಾಂಡ್‌ಗಳು, ಸ್ಟಾಕ್‌ಗಳು, REIT ಗಳು ಮತ್ತು ಅಂತರರಾಷ್ಟ್ರೀಯ ಮಾನ್ಯತೆಗಳಾದ್ಯಂತ ನಿಮ್ಮ ಬಂಡವಾಳವನ್ನು ಹರಡಿ.",
  "strategy_dcaTitle": "ಡಾಲರ್-ವೆಚ್ಚದ ಸರಾಸರಿ (DCA)",
  "strategy_dcaBody": "ಸ್ಥಿರತೆಯು ಪ್ರತಿಭೆಯನ್ನು ಸೋಲಿಸುತ್ತದೆ. ಪರಿಪೂರ್ಣ ಪ್ರವೇಶ ಬಿಂದುವನ್ನು ಆಯ್ಕೆ ಮಾಡಲು ಪ್ರಯತ್ನಿಸುವುದಕ್ಕಿಂತ ಪ್ರತಿ ತಿಂಗಳು ಹೂಡಿಕೆ ಮಾಡುವುದು ಹೆಚ್ಚು ಪರಿಣಾಮಕಾರಿಯಾಗಿದೆ.",
  "strategy_smartGoalsTitle": "ಸ್ಮಾರ್ಟ್ ಗುರಿಗಳು",
  "strategy_smartGoalsBody": "ನಿಮ್ಮ ಗುರಿಗಳು ನಿರ್ದಿಷ್ಟ, ಅಳೆಯಬಹುದಾದ, ಸಾಧಿಸಬಹುದಾದ, ಸಂಬಂಧಿತ ಮತ್ತು ಸಮಯಕ್ಕೆ ಸೀಮಿತವಾಗಿರಬೇಕು.",
  "strategy_503020Title": "50-30-20 ನಿಯಮ",
  "strategy_503020Body": "ಸರಳ ಬಜೆಟ್ ಚೌಕಟ್ಟು: 50% ಅಗತ್ಯಗಳು, 30% ಬಯಸುತ್ತಾರೆ, 20% ಹೂಡಿಕೆ ಮತ್ತು ಗುರಿಗಳು.",
  "strategy_deepDive_allocationTitle": "ಆಸ್ತಿ ಹಂಚಿಕೆ (ಸುಧಾರಿತ)",
  "strategy_deepDive_allocationBody": "ಗುರಿ ಮತ್ತು ಹಾರಿಜಾನ್ ಮೂಲಕ ಹಂಚಿಕೆಯನ್ನು ಹೇಗೆ ನಿರ್ಮಿಸುವುದು, ಅಪಾಯ, ಪರಸ್ಪರ ಸಂಬಂಧ ಮತ್ತು ಮರುಸಮತೋಲನವನ್ನು ಸರಿಹೊಂದಿಸುವುದು ಹೇಗೆ ಎಂದು ತಿಳಿಯಿರಿ.",
  "strategy_deepDive_globalEtfsTitle": "ಜಾಗತಿಕ ಇಟಿಎಫ್‌ಗಳು ಮತ್ತು ಸೂಚ್ಯಂಕಗಳು (ಸುಧಾರಿತ)",
  "strategy_deepDive_globalEtfsBody": "ಜಾಗತಿಕ ಸೂಚ್ಯಂಕಗಳು (ಉದಾ., ಎಸ್&ಪಿ 500), ಇಟಿಎಫ್‌ಗಳು ಮತ್ತು ಶಿಸ್ತಿನಿಂದ ಅಂತರರಾಷ್ಟ್ರೀಯ ಮಾನ್ಯತೆಯನ್ನು ಹೇಗೆ ನಿರ್ಮಿಸುವುದು ಎಂಬುದರ ಕುರಿತು ತಿಳಿಯಿರಿ.",
  "strategy_deepDive_taxesTitle": "ತೆರಿಗೆಗಳು ಮತ್ತು ವರದಿ (ಸುಧಾರಿತ)",
  "strategy_deepDive_taxesBody": "ಪ್ರಮುಖ ತೆರಿಗೆ ಪರಿಕಲ್ಪನೆಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಿ ಮತ್ತು ಹೂಡಿಕೆಗಳನ್ನು ಸುರಕ್ಷಿತವಾಗಿ ವರದಿ ಮಾಡಲು ದಾಖಲೆಗಳನ್ನು ಹೇಗೆ ಇಟ್ಟುಕೊಳ್ಳಬೇಕು.",
  "strategy_premiumLockedBody": "ಪ್ರೀಮಿಯಂ ವಿಷಯ. ಹೂಡಿಕೆ ಡೀಪ್ ಡೈವ್ ಅನ್ನು ಅನ್‌ಲಾಕ್ ಮಾಡಲು ಸೈಬರ್/ಗ್ರಿಮ್/ಹೈವ್ ಥೀಮ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ.",
  "homeShowcaseTitle": "ಶೋಕೇಸ್",
