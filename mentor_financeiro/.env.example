# Copie para `.env` na raiz do pacote `mentor_financeiro` (não commite segredos reais).
#
# RevenueCat: sem chave válida para a plataforma, o app inicia em modo grátis e não chama
# Purchases.configure. Use as chaves públicas do dashboard (ex.: appl_… / goog_…), sem aspas.
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_IOS_API_KEY=
# Opcional: cotações globais Alpha Vantage (prioridade sobre Yahoo quando definido).
ALPHA_VANTAGE_API_KEY=
# Um ou mais e-mails admin (premium), separados por vírgula.
FIREBASE_ADMIN_EMAIL=
