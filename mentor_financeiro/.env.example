# Chaves opcionais — os defaults vazios versionados estão em `assets/dotenv.defaults`.
# Para valores locais, edite `assets/dotenv.defaults` sem commitar segredos, ou
# injete chaves no pipeline de CI de forma segura.
#
# Opcional: cotações globais Alpha Vantage (prioridade sobre Yahoo quando definido).
ALPHA_VANTAGE_API_KEY=
# Um ou mais e-mails admin (premium), separados por vírgula.
FIREBASE_ADMIN_EMAIL=
