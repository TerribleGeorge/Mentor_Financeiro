rules_version = '2';
// Firebase Console → Storage → Regras → colar → Publicar.
// Caminho do app: profile_photos/{userId}/avatar_*.jpg
//
// Leitura e escrita só para o dono da pasta (uid = auth.uid), para
// getDownloadURL / getMetadata / upload funcionarem com a mesma sessão.
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_photos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
          && request.auth.uid == userId;
    }
  }
}
